# JWT Configuration
JWT_SECRET=your-256-bit-secret-key-here-make-it-at-least-32-bytes-long
JWT_EXPIRY_MS=86400000

# Database Configuration (PostgreSQL via Neon / Render)
NEON_DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require

# ImageKit (for image uploads)
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_folder_id

# Spring Profile (dev / prod)
SPRING_PROFILES_ACTIVE=dev