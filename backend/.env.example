# JWT Configuration
JWT_SECRET=your-256-bit-secret-key-here-make-it-at-least-32-bytes-long
JWT_EXPIRY_MS=86400000

# Database Configuration (PostgreSQL)
# Option A: Single DATABASE_URL (recommended for NEON / Render)
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require
# Option B: Individual params (fallback)
DB_PASSWORD=changemeinprod!
SPRING_DATASOURCE_HOST=localhost
SPRING_DATASOURCE_PORT=5432
SPRING_DATASOURCE_DBNAME=blog

# Spring Profile (dev / prod)
SPRING_PROFILES_ACTIVE=dev
